# ============================================
# AI-Powered Security Scanner — Configuration
# ============================================
# Copy this file to '.env' and fill in your values.

# --- Google Drive Authentication ---
# Path to OAuth 2.0 client credentials JSON (downloaded from Google Cloud Console)
GOOGLE_OAUTH_CREDENTIALS_PATH=credentials/client_secret.json

# Path to store/reuse OAuth tokens (auto-generated after first login)
GOOGLE_TOKEN_PATH=credentials/token.json

# --- Domain-Wide Delegation ---
# Target user email to impersonate (e.g. backup@daangnservice.com). 
# Requires Service Account DwD setup matching this email's domain.
IMPERSONATE_USER_EMAIL=backup@daangnservice.com

# --- Scan Scope ---
# Google Drive folder ID to scan. Use 'root' for entire My Drive.
SCAN_FOLDER_ID=1DYRMmGYjvfW5nf-PQP1p48iJKVzZARIe

# --- Google Sheets Report ---
# Spreadsheet ID for report output (from the Google Sheets URL)
# Example: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
REPORT_SPREADSHEET_ID=1gvz8KWhEuJud3EQh8Tk61XH3ihZ7j_ZvPpevogUkQhE

# Sheet name for the report (will be created if it doesn't exist)
REPORT_SHEET_NAME=Security Scan Report

# --- Performance Tuning ---
# Maximum concurrent workers for parallel scanning
MAX_WORKERS=4

# Text chunk size (characters) for Presidio analysis
CHUNK_SIZE=10000

# Chunk overlap (characters) to avoid boundary splits
CHUNK_OVERLAP=200

# --- Rate Limiting (Google Drive API) ---
# Maximum API requests per second
RATE_LIMIT_RPS=10

# --- Output ---
# Directory for JSON report output
OUTPUT_DIR=reports
